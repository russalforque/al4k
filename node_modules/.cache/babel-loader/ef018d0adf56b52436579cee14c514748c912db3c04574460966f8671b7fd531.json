ray-600\">/</span>\r\n                <span class=\"hover:text-white transition-colors duration-300\">Node.js</span>\r\n                <span class=\"text-gray-600\">/</span>\r\n                <span class=\"hover:text-white transition-colors duration-300\">React</span>\r\n                <span class=\"text-gray-600\">/</span>\r\n                <span class=\"hover:text-white transition-colors duration-300\">TypeScript</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"relative mt-8 md:mt-0\">\r\n            <img \r\n              src=\"@/assets/images/Rhazel.jpg\" \r\n              alt=\"Profile\" \r\n              class=\"w-full md:w-full lg:w-full xl:w-3/4 h-[40vh] sm:h-[50vh] md:h-[55vh] object-cover rounded-md shadow-2xl transition-transform duration-500 hover:scale-[1.02]\"\r\n            >\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </transition>\r\n    \r\n    <!-- Main Footer -->\r\n    <Footer />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Footer from './Footer.vue'\r\n\r\nexport default {\r\n  name: 'AboutSection',\r\n  components: {\r\n    Footer\r\n  },\r\n  methods: {\r\n    onEnter(el) {\r\n      el.style.opacity = '0'\r\n      el.style.transform = 'translateY(20px)'\r\n      setTimeout(() => {\r\n        el.style.opacity = '1'\r\n        el.style.transform = 'translateY(0)'\r\n      }, 50)\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* Fade up transition */\r\n.fade-up-enter-active,\r\n.fade-up-leave-active {\r\n  transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);\r\n}\r\n\r\n.fade-up-enter-from,\r\n.fade-up-leave-to {\r\n  opacity: 0;\r\n  transform: translateY(20px);\r\n}\r\n\r\n.fade-up-enter-to,\r\n.fade-up-leave-from {\r\n  opacity: 1;\r\n  transform: translateY(0);\r\n}\r\n\r\n/* Ensure the container has the correct initial state */\r\n.container {\r\n  max-width: 1400px;\r\n  width: 100%;\r\n  margin: 0 auto;\r\n  opacity: 1;\r\n  transform: translateY(0);\r\n  will-change: transform, opacity;\r\n}\r\n\r\n/* Responsive adjustments */\r\n@media (max-width: 640px) {\r\n  .container {\r\n    padding-left: 1rem;\r\n    padding-right: 1rem;\r\n  }\r\n}\r\n\r\n/* Hover effects */\r\n@media (min-width: 768px) {\r\n  .hover\\:-translate-y-0\\.5:hover {\r\n    transform: translateY(-2px);\r\n  }\r\n  \r\n  a:hover {\r\n    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);\r\n  }\r\n}\r\n\r\n/* Smooth scrolling */\r\nhtml {\r\n  scroll-behavior: smooth;\r\n}\r\n</style> "],"mappings":"AA2EA,OAAOA,MAAK,MAAO,cAAa;AAEhC,eAAe;EACbC,IAAI,EAAE,cAAc;EACpBC,UAAU,EAAE;IACVF;EACF,CAAC;EACDG,OAAO,EAAE;IACPC,OAAOA,CAACC,EAAE,EAAE;MACVA,EAAE,CAACC,KAAK,CAACC,OAAM,GAAI,GAAE;MACrBF,EAAE,CAACC,KAAK,CAACE,SAAQ,GAAI,kBAAiB;MACtCC,UAAU,CAAC,MAAM;QACfJ,EAAE,CAACC,KAAK,CAACC,OAAM,GAAI,GAAE;QACrBF,EAAE,CAACC,KAAK,CAACE,SAAQ,GAAI,eAAc;MACrC,CAAC,EAAE,EAAE;IACP;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}